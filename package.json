{
  "name": "readmefy",
  "version": "0.1.0",
  "description": "Deterministic README infrastructure for real repositories.",
  "type": "module",
  "bin": {
    "readmefy": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "action.yml"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gkamel/readmefy.git"
  },
  "bugs": {
    "url": "https://github.com/gkamel/readmefy/issues"
  },
  "homepage": "https://github.com/gkamel/readmefy#readme",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/gkamel"
  },
  "keywords": [
    "readme",
    "documentation",
    "cli",
    "github-action",
    "markdown",
    "open-source",
    "repository",
    "automation",
    "deterministic",
    "infrastructure"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "check": "npm run lint && npm run typecheck && npm run test",
    "verify:examples": "tsx scripts/verify-examples.ts",
    "prepublishOnly": "npm run check && npm run build"
  },
  "dependencies": {
    "commander": "^14.0.1",
    "fast-glob": "^3.3.3",
    "jiti": "^2.6.1",
    "prettier": "^3.6.2",
    "smol-toml": "^1.4.2",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.47.0",
    "@typescript-eslint/parser": "^8.47.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.0"
  }
}
